# ═══════════════════════════════════════════════════════════════
# TG-Digest Environment Configuration
# ═══════════════════════════════════════════════════════════════
#
# ПРИМЕЧАНИЕ: Секреты (пароли, API ключи) читаются из Docker Secrets
# Они НЕ хранятся здесь в .env файле
# 
# Как Docker Secrets работает:
#   1. Значения хранятся в ../tg-digest-secrets/{name}.txt
#   2. В docker-compose.yml указано: secrets: - tg_api_id
#   3. В контейнере доступны как: /run/secrets/tg_api_id
#   4. Python читает их через Path("/run/secrets/{name}").read_text()
#
# Это защищает от:
#   ✓ Случайной коммита в git
#   ✓ Логирования в stdout
#   ✓ Экспозиции в docker inspect
# ═══════════════════════════════════════════════════════════════

# === PostgreSQL (only for docker-compose configuration) ===
POSTGRES_USER=tg_digest
POSTGRES_DB=tg_digest

# === Debugging ===
DEBUG=false

# === Connection Pooling (infrastructure level) ===
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20
